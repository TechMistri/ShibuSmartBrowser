<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="@string/pref_category_general"
        app:iconSpaceReserved="false">

        <ListPreference
            android:defaultValue="@string/search_engine_google"
            android:entries="@array/pref_search_engine_entries"
            android:entryValues="@array/pref_search_engine_values"
            android:key="search_engine"
            android:title="@string/pref_title_search_engine"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:defaultValue="https://www.google.com"
            android:key="homepage"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="@string/pref_title_homepage"
            app:iconSpaceReserved="false" />
            
        <ListPreference
            android:defaultValue="@string/language_english"
            android:entries="@array/pref_language_entries"
            android:entryValues="@array/pref_language_values"
            android:key="language"
            android:title="@string/pref_title_language"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_category_appearance"
        app:iconSpaceReserved="false">

        <ListPreference
            android:defaultValue="@string/theme_system"
            android:entries="@array/pref_theme_entries"
            android:entryValues="@array/pref_theme_values"
            android:key="theme"
            android:title="@string/pref_title_theme"
            app:iconSpaceReserved="false" />

        <SeekBarPreference
            android:defaultValue="100"
            android:key="text_size"
            android:max="200"
            android:min="50"
            android:title="@string/pref_title_text_size"
            app:iconSpaceReserved="false"
            app:showSeekBarValue="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_category_privacy"
        app:iconSpaceReserved="false">

        <Preference
            android:key="clear_data"
            android:title="@string/pref_title_clear_data"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="app_lock"
            android:title="@string/pref_title_app_lock"
            app:iconSpaceReserved="false" />
            
        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="adblock"
            android:title="@string/pref_title_adblock"
            app:iconSpaceReserved="false" />
            
        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="vpn"
            android:title="@string/pref_title_vpn"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_category_downloads"
        app:iconSpaceReserved="false">

        <Preference
            android:key="download_location"
            android:title="@string/pref_title_download_location"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</PreferenceScreen>